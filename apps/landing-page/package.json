{
  "name": "landing-page",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 6312",
    "build": "tsc -b && vite build",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "validate": "bun run check && bun run typecheck && bun run build",
    "precommit": "bun run format && bun run lint && bun run typecheck"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@tailwindcss/vite": "^4.2.2",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
